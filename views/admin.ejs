<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Manofox Admin</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root { --bg: #1a1a2e; --card: #16213e; --text: #fff; --accent: #e94560; --green: #2ecc71; }
        body { font-family: 'Segoe UI', sans-serif; background: var(--bg); color: var(--text); padding: 30px; }
        
        .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
        .date-select { padding: 10px; background: #0f3460; color: white; border: 1px solid #333; border-radius: 6px; cursor: pointer; }
        
        .grid { display: grid; grid-template-columns: repeat(12, 1fr); gap: 20px; margin-bottom: 25px; }
        .col-3 { grid-column: span 3; } .col-6 { grid-column: span 6; } .col-9 { grid-column: span 9; } .col-12 { grid-column: span 12; }

        .card { background: var(--card); padding: 25px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.3); }
        .card h2 { margin: 0 0 10px 0; color: #a0a0a0; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; }
        .big-num { font-size: 2.2rem; font-weight: bold; color: var(--text); }
        .sub-text { font-size: 0.9rem; color: var(--green); margin-top: 5px; }

        table { width: 100%; border-collapse: collapse; margin-top: 15px; font-size: 0.9rem; }
        th, td { text-align: left; padding: 12px; border-bottom: 1px solid #333; }
        th { color: #888; font-weight: normal; background: #0f2444; }
        tr:hover { background: #1f2e50; }
        
        .tag { padding: 3px 8px; border-radius: 4px; font-size: 0.75rem; font-weight: bold; }
        .tag-mobile { background: #e67e22; color: white; }
        .tag-desktop { background: #3498db; color: white; }

        input, textarea { width: 100%; padding: 12px; background: #0f3460; border: 1px solid #222; color: white; margin-bottom: 15px; border-radius: 6px; box-sizing: border-box;}
        button { background: var(--accent); color: white; border: none; padding: 12px 25px; cursor: pointer; border-radius: 6px; font-weight: bold; transition: 0.3s; }
        button:hover { background: #d63d56; }
    </style>
</head>
<body>

    <div class="header">
        <h1>🦊 Manofox Agency</h1>
        <div style="display:flex; gap:15px; align-items:center;">
            <select class="date-select" onchange="window.location.href='/admin?days='+this.value">
                <option value="7" <%= selectedDays == 7 ? 'selected' : '' %>>Last 7 Days</option>
                <option value="14" <%= selectedDays == 14 ? 'selected' : '' %>>Last 14 Days</option>
                <option value="21" <%= selectedDays == 21 ? 'selected' : '' %>>Last 21 Days</option>
                <option value="30" <%= selectedDays == 30 ? 'selected' : '' %>>Last 30 Days</option>
            </select>
            <a href="/logout" style="color: #e94560; text-decoration: none; font-weight: bold;">Logout</a>
        </div>
    </div>

    <div class="grid">
        <div class="card col-3">
            <h2>Total Clicks</h2>
            <div class="big-num"><%= totalViews %></div>
            <div class="sub-text">▲ Visits in <%= selectedDays %> days</div>
        </div>
        <div class="card col-3">
            <h2>Total Leads</h2>
            <div class="big-num"><%= totalLeads %></div>
            <div class="sub-text">▲ Form submissions</div>
        </div>
        <div class="card col-3">
            <h2>Bounce Rate</h2>
            <div class="big-num"><%= bounceRate %>%</div>
            <div class="sub-text" style="color: #f1c40f;">Avg. <%= bounceRate %>%</div>
        </div>
        <div class="card col-3">
            <h2>Avg. Time</h2>
            <div class="big-num"><%= avgTime %></div>
            <div class="sub-text">Per Session</div>
        </div>
    </div>

    <div class="grid">
        <div class="card col-9">
            <h2>Traffic Trends</h2>
            <div style="height: 300px;"><canvas id="chart"></canvas></div>
        </div>
        <div class="card col-3">
            <h2>Device Type</h2>
            <div style="height: 250px;"><canvas id="pie"></canvas></div>
        </div>
    </div>

    <div class="grid">
        <div class="card col-6">
            <h2>📩 Client Inquiries (Emails Received)</h2>
            <% if (leads.length === 0) { %>
                <p style="color:#666; font-style:italic; margin-top:20px;">No messages yet.</p>
            <% } else { %>
                <div style="overflow-x:auto;">
                    <table>
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Name / Phone</th>
                                <th>Message</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% leads.forEach(function(lead) { %>
                                <tr>
                                    <td style="white-space:nowrap; font-size:0.8rem; color:#888;">
                                        <%= lead.date.toLocaleDateString() %>
                                    </td>
                                    <td>
                                        <strong><%= lead.name %></strong><br>
                                        <span style="color: #e94560; font-size: 0.8rem;"><%= lead.email %></span><br>
                                        <span style="font-size:0.8rem; color:#888;"><%= lead.phone %></span>
                                    </td>
                                    <td style="font-size:0.85rem;"><%= lead.message %></td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </div>

        <div class="card col-6">
            <h2>👀 Live Visitor Log & Sources</h2>
            <p style="font-size:0.8rem; color:#888; margin-bottom:15px;">
                Shows where users came from (Referrer) and what keywords they might have used.
            </p>
            <% if (recentVisits.length === 0) { %>
                <p style="color:#666; font-style:italic;">No visits recorded yet.</p>
            <% } else { %>
                <div style="overflow-x:auto;">
                    <table>
                        <thead>
                            <tr>
                                <th>Time</th>
                                <th>Device</th>
                                <th>Traffic Source / Referrer</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% recentVisits.forEach(function(visit) { %>
                                <tr>
                                    <td style="font-size:0.8rem; color:#888;">
                                        <%= visit.date.toLocaleTimeString() %>
                                    </td>
                                    <td>
                                        <span class="tag <%= visit.device === 'Mobile' ? 'tag-mobile' : 'tag-desktop' %>">
                                            <%= visit.device %>
                                        </span>
                                    </td>
                                    <td style="font-size:0.85rem;">
                                        <% if (visit.referrer && visit.referrer !== 'Direct / Unknown') { %>
                                            <span style="color: #2ecc71;">🔗 <%= visit.referrer.substring(0, 30) %>...</span>
                                        <% } else { %>
                                            <span style="color: #666;">Direct Entry</span>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </div>
    </div>


<div class="card col-12" style="margin-top: 20px;">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:15px;">
        <h2>🔍 Top Google Search Queries (Last 30 Days)</h2>
        <span style="background:white; color:#333; padding:2px 8px; border-radius:4px; font-size:0.7rem; font-weight:bold;">OFFICIAL GOOGLE DATA</span>
    </div>

    <% if (!googleSearchData || googleSearchData.length === 0) { %>
        <p style="color:#666; font-style:italic;">No search data available yet. (Google takes 48-72 hours to start showing data for new sites)</p>
    <% } else { %>
        <div style="overflow-x:auto;">
            <table>
                <thead>
                    <tr>
                        <th>Search Query</th>
                        <th>Clicks</th>
                        <th>Impressions</th>
                        <th>Avg. Position</th>
                    </tr>
                </thead>
                <tbody>
                    <% googleSearchData.forEach(function(row) { %>
                        <tr>
                            <td><strong><%= row.keys[0] %></strong></td>
                            <td style="color: #2ecc71; font-weight:bold;"><%= row.clicks %></td>
                            <td><%= row.impressions %></td>
                            <td>#<%= row.position.toFixed(1) %></td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    <% } %>
</div>

    <div class="grid">
        <div class="card col-12">
            <div style="display:flex; justify-content:space-between; margin-bottom: 20px;">
                <div>
                    <h2>🚀 Smart SEO Manager (Visibility Strategy)</h2>
                    <span style="font-size: 0.8rem; color: #888;">These are the Keywords your page is currently visible for (Auto-Generated)</span>
                </div>
                <a href="/admin/force-update" style="background: var(--accent); color: white; padding: 8px 15px; text-decoration: none; border-radius: 4px; font-size: 0.8rem; font-weight: bold;">⚡ Force Update</a>
            </div>
            
            <form action="/admin/seo" method="POST">
                <div class="grid" style="margin-bottom: 0;">
                    <div class="col-3">
                        <label style="color:#888; font-size:0.9rem;">Browser Title</label>
                        <input type="text" name="title" value="<%= seo ? seo.title : '' %>">
                    </div>
                    <div class="col-9">
                        <label style="color:#888; font-size:0.9rem;">Targeted Keywords (Search Terms)</label>
                        <input type="text" name="keywords" value="<%= seo ? seo.keywords : '' %>" readonly style="opacity: 0.7; cursor: not-allowed; color: #2ecc71;">
                    </div>
                </div>
                <label style="color:#888; font-size:0.9rem;">Meta Description</label>
                <textarea name="desc" rows="2"><%= seo ? seo.desc : '' %></textarea>
                
                <button type="submit">Save SEO Changes</button>
            </form>
        </div>
    </div>

    <script>
        const daily = <%- JSON.stringify(dailyStats) %>;
        const device = <%- JSON.stringify(deviceStats) %>;

        // TRAFFIC CHART
        new Chart(document.getElementById('chart'), {
            type: 'line',
            data: {
                labels: daily.map(d => d._id),
                datasets: [{ 
                    label: 'Visits', 
                    data: daily.map(d => d.count), 
                    borderColor: '#e94560', 
                    backgroundColor: 'rgba(233, 69, 96, 0.1)', 
                    borderWidth: 3,
                    fill: true,
                    tension: 0.4
                }]
            },
            options: { maintainAspectRatio: false, scales: { y: { beginAtZero: true, grid: { color: '#333' } }, x: { grid: { display: false } } }, plugins: { legend: { display: false } } }
        });

        // PIE CHART
        new Chart(document.getElementById('pie'), {
            type: 'doughnut',
            data: {
                labels: device.map(d => d._id),
                datasets: [{ data: device.map(d => d.count), backgroundColor: ['#e94560', '#16213e'], borderWidth: 0 }]
            },
            options: { maintainAspectRatio: false, cutout: '70%', plugins: { legend: { position: 'bottom', labels: { color: '#fff' } } } }
        });
    </script>
</body>
</html>

